## 复制本文件为 .env 后填写真实密钥（不要提交 .env）

# 阿里云 DashScope
ALIYUN_DASHSCOPE_API_KEY=
ALIYUN_DASHSCOPE_APP_SECRET=

# 豆包 / 火山方舟
DOUBAO_API_KEY=
DOUBAO_APP_SECRET=
DOUBAO_V4_API_KEY=
DOUBAO_V4_APP_SECRET=

# Gemini / Nano Banana
NANO_BANANA_API_KEY=
NANO_BANANA_APP_SECRET=

# 星流 LibLib
STARFLOW_LIBLIB_API_KEY=
STARFLOW_LIBLIB_APP_SECRET=

# DeepSeek（V4 Pro / V4 Flash：在 model_presets.py 将 ACTIVE_LLM_VENDOR 设为 deepseek_v4_pro）
DEEPSEEK_API_KEY=
DEEPSEEK_APP_SECRET=

# Gribo
GRIBO_TEXT_API_KEY=
GRIBO_IMG_API_KEY=

# Step2 宫格校验 / 重试（可选；不配则用代码内默认）
# STEP2_MAX_BATCH_RETRIES=5
# GRID_SPACING_MAX_CV=0.50
# GRID_PEAK_ANCHOR_MAX_DEV_RATIO=0.15
# 飞书预览阶段：默认已在代码里跳过自动线格校验；若要预览时也校验，取消注释：
# GRID_SKIP_LAYOUT_VALIDATE=0

# 飞书机器人（与上列主链路密钥分开配置）：见同目录 .env.feishu.example

# 火山引擎 (豆包语音合成) 配置
VOLC_TTS_API_KEY=
VOLC_TTS_APPID=

